					</li>
					<li>
						<foundation Class="IdeoFoundation_Deity">
							<def>Deity</def>
							<place>Chelis</place>
							<deities>
								<li>
									<name>Rerobai</name>
									<type>Spirit of Creation</type>
									<gender>Male</gender>
									<iconPath>UI/Deities/DeityGeneric</iconPath>
									<relatedMeme>Structure_TheistEmbodied</relatedMeme>
								</li>
								<li>
									<name>Queabrei</name>
									<type>Spirit of War</type>
									<gender>Female</gender>
									<iconPath>UI/Deities/DeityGeneric</iconPath>
									<relatedMeme>Supremacist</relatedMeme>
								</li>
								<li>
									<name>Reox</name>
									<type>God of Life</type>
									<gender>Male</gender>
									<iconPath>UI/Deities/DeityGeneric</iconPath>
									<relatedMeme>Structure_TheistEmbodied</relatedMeme>
								</li>
