									<def>Funeral</def>
								</behavior>
								<triggers>
									<li Class="RitualObligationTrigger_MemberDied">
										<mustBePlayerIdeo>True</mustBePlayerIdeo>
									</li>
								</triggers>
								<outcomeEffect Class="RitualOutcomeEffectWorker_FromQuality">
									<def>AttendedFuneral</def>
									<compDatas>
										<li IsNull="True" />
