						<id>7</id>
						<development IsNull="True" />
					</li>
					<li>
						<foundation Class="IdeoFoundation_Deity">
							<def>Deity</def>
							<place>Rhydell</place>
							<deities>
								<li>
									<name>God</name>
									<type>Creator of the Universe</type>
									<gender>Female</gender>
									<iconPath>UI/Deities/DeityGeneric</iconPath>
									<relatedMeme>Structure_OriginChristian</relatedMeme>
								</li>
							</deities>
						</foundation>
						<name>Rhydellian Way</name>
						<adjective>Post-Lutheran</adjective>
						<memberName>Post-Lutheran</memberName>
						<leaderTitleMale>Divine Minister</leaderTitleMale>
						<leaderTitleFemale>Divine Minister</leaderTitleFemale>
						<description>The people of the savage forest moon Rhydell worked together in harmony, and built a great &lt;color=#D09B61FF&gt;Image of Family&lt;/color&gt; to honor &lt;color=#D09B61FF&gt;God&lt;/color&gt;, who taught them the true value of family. An evil deepcorp executive and his deepcorp enforcers enslaved the worshippers of &lt;color=#D09B61FF&gt;God&lt;/color&gt;. One hero named Luca 'Luuk' van 't Wout killed a hundred of the deepcorp enforcers using a sniper rifle, and &lt;color=#D09B61FF&gt;God&lt;/color&gt; guided him by speaking through the &lt;color=#D09B61FF&gt;Dowbringer&lt;/color&gt;. Luuk gathered the Post-Lutherans in a communication center and taught them of &lt;color=#D09B61FF&gt;God&lt;/color&gt;'s wisdom.</description>
						<descriptionTemplate>The people of the savage forest moon Rhydell worked together in harmony, and built a great %%altar0_name%% to honor %%deity0_name%%, who taught them the true value of family. An evil deepcorp executive and his deepcorp enforcers enslaved the worshippers of %%deity0_name%%. One hero named Luca 'Luuk' van 't Wout killed a hundred of the deepcorp enforcers using a sniper rifle, and %%deity0_name%% guided him by speaking through the %%relic0_name%%. Luuk gathered the %%memberNamePlural%% in a communication center and taught them of %%deity0_name%%'s wisdom.</descriptionTemplate>
						<culture>Rustican</culture>
						<iconDef>SpiralsC</iconDef>
						<colorDef>DarkSapphire</colorDef>
						<primaryFactionColor>RGBA(0.436, 0.386, 0.857, 1.000)</primaryFactionColor>
						<memes>
							<li>Structure_OriginChristian</li>
							<li>Collectivist</li>
						</memes>
						<precepts>
							<li>
								<name>virginity of female</name>
								<def>Virgin_PreciousF</def>
								<ID>1486</ID>
								<randomSeed>-985596648</randomSeed>
								<usesDefiniteArticle>True</usesDefiniteArticle>
							</li>
							<li>
								<name>drug use</name>
								<def>DrugUse_MedicalOnly</def>
								<ID>1487</ID>
								<randomSeed>1585865322</randomSeed>
								<usesDefiniteArticle>True</usesDefiniteArticle>
							</li>
							<li Class="Precept_Ritual">
								<name>Interment of God</name>
								<def>Funeral</def>
								<ID>1488</ID>
								<randomSeed>647047668</randomSeed>
								<usesDefiniteArticle>True</usesDefiniteArticle>
								<nameMaker>NamerRitualFuneral</nameMaker>
								<ritualOnlyForIdeoMembers>True</ritualOnlyForIdeoMembers>
								<ritualExpectedDesc>You can hold a {IDEOLIGION_adjective} funeral for {PAWN_nameDef}.</ritualExpectedDesc>
								<ritualExpectedDescNoAdjective>You can hold a funeral for {PAWN_nameDef}.</ritualExpectedDescNoAdjective>
								<playsIdeoMusic>True</playsIdeoMusic>
								<generatedAttachedReward>True</generatedAttachedReward>
								<sourcePattern>FuneralStandard</sourcePattern>
								<obligationTargetFilter Class="RitualObligationTargetWorker_GraveWithTarget">
									<def>GraveWithTargetsCorpse</def>
									<parent>Precept_1488</parent>
								</obligationTargetFilter>
								<targetFilter IsNull="True" />
